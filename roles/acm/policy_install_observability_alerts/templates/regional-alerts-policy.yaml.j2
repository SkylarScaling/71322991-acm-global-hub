---
apiVersion: policy.open-cluster-management.io/v1
kind: Policy
metadata:
  name: global-to-regional-alerts-policy
  namespace: default
spec:
  remediationAction: enforce
  disabled: false
  policy-templates:
    - objectDefinition:
        apiVersion: policy.open-cluster-management.io/v1
        kind: ConfigurationPolicy
        metadata:
          name: regional-observability-config
          annotations:
            # Tell ACM's policy engine to ignore template brackets in the payloads below
            policy.open-cluster-management.io/disable-templates: "true"
        spec:
          remediationAction: enforce
          severity: high
          object-templates:
            # PAYLOAD 1: The Alertmanager Config
            - complianceType: musthave
              objectDefinition:
                apiVersion: v1
                kind: Secret
                metadata:
                  name: alertmanager-config
                  namespace: open-cluster-management-observability
                type: Opaque
                data:
                  # Since the Secret naturally expects Base64, we can safely leave this as b64encode
                  alertmanager.yaml: {{ lookup('template', 'alertmanager.yaml.j2') | b64encode }}

            # PAYLOAD 2: The Custom Rules
            - complianceType: musthave
              objectDefinition:
                apiVersion: v1
                kind: ConfigMap
                metadata:
                  name: thanos-ruler-custom-rules
                  namespace: open-cluster-management-observability
                data:
                  # We use 'data' and 'indent' so the MCO operator correctly detects the plaintext file
                  custom_rules.yaml: |
{{ lookup('template', 'custom_rules.yaml.j2') | indent(20, True) }}

            # PAYLOAD 3: The Custom Metrics Allowlist
            - complianceType: musthave
              objectDefinition:
                apiVersion: v1
                kind: ConfigMap
                metadata:
                  name: observability-metrics-custom-allowlist
                  namespace: open-cluster-management-observability
                data:
                  metrics_list.yaml: |
                    names:
                      - kube_job_failed